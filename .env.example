# Postgres (Neon em producao: postgresql://user:pass@host/db?sslmode=require)
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/album_catalog

# JWT - gere um segredo forte: openssl rand -hex 32
JWT_SECRET=troque-por-um-segredo-forte
JWT_EXPIRES_IN=7d

# Spotify (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Porta (Railway/Render injetam PORT automaticamente)
PORT=3333

# Origens do frontend liberadas no CORS (separadas por virgula)
# Producao: https://seu-app.vercel.app
FRONTEND_URLS=http://localhost:3000,http://127.0.0.1:3000

# Ambiente: development | production | test
# Em production o Swagger /docs fica desabilitado
NODE_ENV=development

# Teto de cadastros (0 = sem limite)
MAX_USERS=25
